{
  "name": "canon-dashboard",
  "icon": "assets/icon.png",
  "displayName": "Canon Dashboard",
  "description": "Engineering principles-as-code dashboard — visualize your codebase graph and feed context into Cursor's AI chat",
  "version": "0.1.0",
  "publisher": "canon",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization"
  ],
  "activationEvents": [
    "workspaceContains:.canon"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "canon.openDashboard",
        "title": "Canon: Open Dashboard"
      },
      {
        "command": "canon.refreshGraph",
        "title": "Canon: Refresh Graph",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "when": "activeWebviewPanelId == canonDashboard",
          "command": "canon.refreshGraph",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build:extension": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "build:webview": "node build-webview.mjs",
    "build": "npm run build:extension && npm run build:webview",
    "watch:extension": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch",
    "watch:webview": "node build-webview.mjs --watch",
    "watch": "npm run watch:extension & npm run watch:webview",
    "package": "vsce package",
    "test": "vitest run"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.0",
    "@semantic-release/release-notes-generator": "^14.0.0",
    "@types/d3": "^7.4.3",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "0.25.0",
    "esbuild-svelte": "^0.9.4",
    "semantic-release": "^24.0.0",
    "semantic-release-vsce": "^5.7.0",
    "svelte": "^5.54.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
}
