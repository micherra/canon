{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",

  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on",
        "useSortedAttributes": "on",
        "useSortedInterfaceMembers": "on",
        "useSortedKeys": "on"
      }
    },
    "enabled": true
  },

  "files": {
    "ignoreUnknown": true,
    "includes": [
      "mcp-server/src/**/*.{ts,tsx,js,jsx,mts,cts,cjs,mjs,json,jsonc}",

      "!**/*.generated.*",
      "!**/*.min.*",

      "!dist",
      "!build",
      "!.next",
      "!coverage",
      "!.turbo",
      "!tmp",
      "!.cache"
    ],
    "maxSize": 400000
  },

  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },

  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },

  "linter": {
    "enabled": true,
    "rules": {
      "complexity": {
        "noExcessiveCognitiveComplexity": {
          "level": "error",
          "options": { "maxAllowedComplexity": 12 }
        },
        "noExcessiveLinesPerFunction": {
          "level": "error",
          "options": { "maxLines": 60 }
        },
        "noForEach": "error",
        "useArrowFunction": "error",
        "useLiteralKeys": "error",
        "useMaxParams": {
          "level": "error",
          "options": { "max": 4 }
        }
      },

      "correctness": {
        "noUndeclaredDependencies": {
          "level": "error",
          "options": {
            "devDependencies": [
              "**/*.test.*",
              "**/*.spec.*",
              "**/test/**",
              "**/tests/**",
              "**/__tests__/**",
              "**/vitest.setup.*",
              "**/vite.config.*",
              "**/vitest.config.*",
              "**/jest.config.*",
              "**/playwright.config.*",
              "**/storybook/**",
              "**/*.stories.*",
              "**/.storybook/**",
              "**/scripts/**"
            ],
            "optionalDependencies": true,
            "peerDependencies": true
          }
        },
        "noUnusedFunctionParameters": "warn",
        "noUnusedImports": "error",
        "noUnusedVariables": "error",
        "useExhaustiveDependencies": "off"
      },

      "performance": {
        "noAwaitInLoops": "on",
        "noBarrelFile": "on",
        "noDelete": "on"
      },
      "recommended": true,

      "style": {
        "noNonNullAssertion": "off",
        "noParameterAssign": "on",
        "useConsistentTypeDefinitions": {
          "level": "warn",
          "options": { "style": "type" }
        },
        "useConst": "error",
        "useImportType": "error",
        "useNodejsImportProtocol": "error",
        "useTemplate": "error"
      },

      "suspicious": {
        "noAssignInExpressions": "on",
        "noConsole": "off",
        "noEmptyBlockStatements": "error",
        "noExplicitAny": "error",
        "noTemplateCurlyInString": "off"
      }
    }
  },

  "overrides": [
    {
      "includes": ["mcp-server/src/**/*.test.{ts,tsx,js,jsx}", "mcp-server/src/**/*.spec.{ts,tsx,js,jsx}"],
      "linter": {
        "rules": {
          "complexity": {
            "noExcessiveCognitiveComplexity": "off",
            "noExcessiveLinesPerFunction": "off",
            "useArrowFunction": "off"
          },
          "performance": {
            "noDelete": "off"
          },
          "suspicious": {
            "noExplicitAny": "off"
          }
        }
      }
    },
    {
      "includes": ["**/*.d.ts"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedFunctionParameters": "off",
            "noUnusedVariables": "off"
          }
        }
      }
    },
    {
      "includes": ["mcp-server/src/ui/**/*.{ts,tsx,js,jsx}"],
      "linter": {
        "rules": {
          "correctness": {
            "noUndeclaredDependencies": "off"
          }
        }
      }
    }
  ],

  "vcs": {
    "clientKind": "git",
    "defaultBranch": "main",
    "enabled": true,
    "useIgnoreFile": true
  }
}
